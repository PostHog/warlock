{
  "name": "@posthog/warlock",
  "version": "0.1.0",
  "description": "Security scanner for PostHog's agentic flows",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PostHog/warlock.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && mkdir -p dist/scanner/rules && cp src/scanner/rules/*.yar dist/scanner/rules/",
    "prepare": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "yara",
    "security",
    "scanner"
  ],
  "engines": {
    "node": "^20.20.0 || >=22.22.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@virustotal/yara-x": "^1.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
